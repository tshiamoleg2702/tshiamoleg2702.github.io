{
  "name": "@workspace/portfolio",
  "version": "1.0.0",
  "description": "GitVitae — spin up a beautiful, hosted portfolio in minutes by editing one config file.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --config vite.config.ts --host 0.0.0.0",
    "build": "node scripts/generate-resume.mjs && vite build --config vite.config.ts",
    "lint": "eslint .",
    "format-check": "prettier -c \"src/**/*.{js,jsx,ts,tsx,css,md}\"",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,css,md}\"",
    "generate:resume": "node scripts/generate-resume.mjs",
    "serve": "vite preview --config vite.config.ts --host 0.0.0.0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "check-config": "node scripts/check-config.mjs",
    "fix-config": "node scripts/check-config.mjs --fix",
    "upgrade-template": "node scripts/upgrade-template.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.5",
    "@eslint/js": "^10.0.1",
    "@radix-ui/react-dialog": "^1.1.7",
    "@radix-ui/react-label": "^2.1.3",
    "@radix-ui/react-separator": "^1.1.3",
    "@radix-ui/react-slot": "^1.2.0",
    "@radix-ui/react-toast": "^1.2.7",
    "@radix-ui/react-toggle": "^1.1.3",
    "@radix-ui/react-tooltip": "^1.2.0",
    "@replit/vite-plugin-cartographer": "^0.5.1",
    "@replit/vite-plugin-runtime-error-modal": "^0.0.6",
    "@rollup/plugin-yaml": "^4.1.2",
    "@tailwindcss/typography": "^0.5.15",
    "@tailwindcss/vite": "^4.1.14",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.4",
    "@vitest/coverage-v8": "^4.1.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "framer-motion": "^12.23.24",
    "happy-dom": "^20.9.0",
    "js-yaml": "^4.1.1",
    "lucide-react": "^0.545.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "qrcode": "^1.5.4",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-icons": "^5.4.0",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.14",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.8.3",
    "vite": "^7.3.2",
    "vitest": "^4.1.5",
    "wouter": "^3.3.5"
  },
  "dependencies": {
    "@fontsource/cormorant-garamond": "^5.2.11",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@mlc-ai/web-llm": "^0.2.83",
    "@radix-ui/react-progress": "^1.1.8",
    "lenis": "^1.3.23",
    "radix-ui": "^1.4.3",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  }
}
